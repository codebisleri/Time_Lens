# ── Time Lens Frontend environment ───────────────────────────────────────────
# Copy to .env.local and adjust. All client-exposed vars MUST be NEXT_PUBLIC_*.

# Base URL of the backend API (when available). Leave blank to rely on mocks.
NEXT_PUBLIC_API_BASE_URL=

# Toggle the mock API adapter. When true, the service layer returns fixtures
# instead of hitting the network — lets the whole app run with no backend.
NEXT_PUBLIC_USE_MOCKS=true

# Simulated latency (ms) for mock responses, to exercise loading states.
NEXT_PUBLIC_MOCK_LATENCY=400

# App display name (branding).
NEXT_PUBLIC_APP_NAME=Time Lens

# Optional: server-side proxy target for /api/* rewrites (keeps cookies same-origin).
# API_PROXY_TARGET=http://localhost:8000

# ── Time Lens AI Assistant (DEMO ONLY) ───────────────────────────────────────
# Server-side Anthropic API key for the /api/assistant proxy. NEVER prefix this
# with NEXT_PUBLIC_ (that would expose it to the browser). When unset, the
# assistant shows a "not configured" message and the rest of the app is
# unaffected. This is a demo integration — see the release notes for production
# hardening (auth, rate limiting, streaming).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-6). e.g. claude-haiku-4-5 for
# a cheaper/faster demo, or claude-opus-4-8 for the most capable answers.
# ASSISTANT_MODEL=claude-sonnet-4-6
# Kill switch. Set to false/0/no/off to fully disable the assistant (the floating
# widget is hidden and the API returns "unavailable"). Default: enabled.
# ENABLE_AI_ASSISTANT=true
#
# Desktop: the packaged app reads these at runtime from an OS env var OR an
# optional `.env` placed next to the app's resources folder (resolved via
# process.resourcesPath) — no rebuild required. Missing values never block
# startup; the assistant simply shows a "not configured" message.
