# ── Time Lens Frontend environment ───────────────────────────────────────────
# Copy to .env.local and adjust. All client-exposed vars MUST be NEXT_PUBLIC_*.

# Base URL of the backend API (when available). Leave blank to rely on mocks.
NEXT_PUBLIC_API_BASE_URL=

# Toggle the mock API adapter. When true, the service layer returns fixtures
# instead of hitting the network — lets the whole app run with no backend.
NEXT_PUBLIC_USE_MOCKS=true

# Simulated latency (ms) for mock responses, to exercise loading states.
NEXT_PUBLIC_MOCK_LATENCY=400

# App display name (branding).
NEXT_PUBLIC_APP_NAME=Time Lens

# Optional: server-side proxy target for /api/* rewrites (keeps cookies same-origin).
# API_PROXY_TARGET=http://localhost:8000
