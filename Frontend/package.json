{
  "name": "time-lens-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Time Lens — retail demand forecasting platform (frontend + desktop shell)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "standalone:prepare": "node scripts/prepare-standalone.mjs",
    "desktop:prepare": "node scripts/prepare-standalone.mjs",
    "build:web": "next build && npm run standalone:prepare",
    "desktop": "concurrently -k -n web,electron -c blue,green \"next dev\" \"wait-on http://127.0.0.1:3000 && electron electron/main.js\"",
    "desktop:start": "electron electron/main.js",
    "desktop:win": "npm run build:web && electron-builder --win nsis portable --x64",
    "desktop:mac": "npm run build:web && electron-builder --mac dmg zip",
    "desktop:dist": "npm run build:web && electron-builder"
  },
  "build": {
    "appId": "com.timelens.desktop",
    "productName": "Time Lens",
    "copyright": "Time Lens",
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.timelens.ai/releases"
      }
    ],
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!**/node_modules/**",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/semver/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*"
    ],
    "asar": true,
    "afterPack": "electron/after-pack.js",
    "extraResources": [
      {
        "from": "../Backend/dist/backend",
        "to": "backend"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Time Lens",
      "uninstallDisplayName": "Time Lens",
      "artifactName": "TimeLens-Setup.${ext}"
    },
    "portable": {
      "artifactName": "TimeLens.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "identity": null,
      "artifactName": "TimeLens-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "TimeLens-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-table": "^8.20.6",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "echarts": "^5.5.1",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.469.0",
    "next": "15.1.0",
    "next-themes": "^0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wait-on": "^9.0.10"
  }
}
