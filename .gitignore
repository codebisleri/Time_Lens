# ── Time Lens — repository ignore (D.7) ──────────────────────────────────────
# Keeps generated/huge artifacts out of git so `git add .` is safe to run.

# Node / Next.js (root + Frontend)
node_modules/
**/node_modules/
.next/
**/.next/
out/
**/out/

# Electron build output
dist-desktop/
**/dist-desktop/
Frontend/dist/

# Python backend — PyInstaller output, build temp, virtualenv, caches
Backend/dist/
Backend/build/
Backend/venv/
Backend/.venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Databases / runtime data (created in the user-data dir at runtime)
*.db
*.sqlite
*.sqlite3

# Runtime-uploaded datasets — per-upload CSVs the backend writes to api_data/
# at runtime (machine-specific; not for distribution).
Backend/api_data/

# Large release binaries — keep the docs/notes, drop the installers
*.exe
*.dmg
*.zip
*.7z
*.blockmap
*.app/
# macOS packaging output (electron-builder) — incl. latest-mac.yml update feed
Frontend/MAC/

# Environment / secrets
.env
.env.*
!.env.example
# Committed production defaults for the desktop build (no secrets) — needed so
# the macOS CI build (which has no .env.local) doesn't fall back to mock mode.
!.env.production

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.log

# Assistant-local project memory (not for distribution)
.claude/
